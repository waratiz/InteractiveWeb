<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Search Results</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

  <h1>Search Results</h1>

  <p>Search keyword: "<%= name %>"</p>

  <% if (books.length === 0) { %>
    <p>No books found.</p>
  <% } %>

  <ul>
    <% books.forEach(book => { %>
      <li><%= book.bookNo %> - <%= book.bookName %></li>
    <% }) %>
  </ul>

  <br>
  <a href="/books">Back to Books</a>

</body>
</html>
